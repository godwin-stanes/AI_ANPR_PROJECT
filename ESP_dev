/*
  🚗 SMART GATE SYSTEM - ESP32 DEV BOARD CODE
  Main Controller with Hardware Integration
  
  Upload to: ESP32 Development Board
  
  GPIO Connections (As configured):
  ├─ GPIO5   → Ultrasonic TRIG
  ├─ GPIO15  → Ultrasonic ECHO
  ├─ GPIO18  → Servo Motor Signal
  ├─ GPIO21  → LCD SDA (I2C)
  ├─ GPIO22  → LCD SCL (I2C)
  ├─ GPIO25  → Red LED
  ├─ GPIO26  → Yellow LED
  ├─ GPIO27  → Green LED
  └─ GPIO34  → IR Sensor
*/

#include <WiFi.h>
#include <HTTPClient.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <ESP32Servo.h>

// ============================================
// PIN DEFINITIONS
// ============================================
#define IR_SENSOR       34
#define RED_LED         25
#define YELLOW_LED      26
#define GREEN_LED       27
#define SERVO_PIN       18
#define ULTRASONIC_TRIG 5
#define ULTRASONIC_ECHO 15

// ============================================
// WiFi Configuration - CHANGE THESE!
// ============================================
const char* ssid = "syedhaja";            // WiFi name
const char* password = "thasneem2011";    // WiFi password

// ============================================
// Server Configuration
// ============================================
// Frontend running at http://localhost:5000
// GitHub: https://github.com/godwin-stanes/AI_ANPR_PROJECT.git
String serverIP = "192.168.1.7";          // Flask/Frontend server IP
String camIP = "192.168.1.8";             // ESP32-CAM IP

// ============================================
// Objects
// ============================================
LiquidCrystal_I2C lcd(0x27, 16, 2);      // LCD address 0x27, 16x2 display
Servo gateServo;

// ============================================
// Variables
// ============================================
long duration;
int distance;
String lastPlate = "";
String lastStatus = "";
bool gateOpen = false;
unsigned long lastDetectionTime = 0;

// ============================================
// Setup
// ============================================
void setup() {
  Serial.begin(115200);
  delay(2000);
  
  Serial.println("\n\n=================================");
  Serial.println("🚗 SMART GATE - ESP32 DEV BOARD");
  Serial.println("=================================");
  
  // Initialize pins
  pinMode(IR_SENSOR, INPUT);
  pinMode(RED_LED, OUTPUT);
  pinMode(YELLOW_LED, OUTPUT);
  pinMode(GREEN_LED, OUTPUT);
  pinMode(ULTRASONIC_TRIG, OUTPUT);
  pinMode(ULTRASONIC_ECHO, INPUT);
  
  // Turn off all LEDs
  digitalWrite(RED_LED, LOW);
  digitalWrite(YELLOW_LED, LOW);
  digitalWrite(GREEN_LED, LOW);
  
  // Initialize servo
  gateServo.attach(SERVO_PIN);
  gateServo.write(0);  // Close gate
  Serial.println("✓ Servo ready (closed)");
  
  // Initialize LCD
  Wire.begin(GPIO_NUM_21, GPIO_NUM_22);  // SDA=21, SCL=22
  lcd.init();
  lcd.backlight();
  lcd.print("SMART GATE");
  lcd.setCursor(0, 1);
  lcd.print("Initializing...");
  Serial.println("✓ LCD ready");
  
  delay(1000);
  
  // Connect to WiFi
  Serial.println("📡 Connecting to WiFi...");
  WiFi.begin(ssid, password);
  
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    delay(500);
    Serial.print(".");
    attempts++;
  }
  
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n✓ WiFi Connected!");
    Serial.print("📍 IP: ");
    Serial.println(WiFi.localIP());
    
    lcd.clear();
    lcd.print("WiFi OK");
    lcd.setCursor(0, 1);
    lcd.print(WiFi.localIP().toString());
    delay(2000);
  } else {
    Serial.println("\n⚠️ WiFi failed - continuing offline");
    lcd.clear();
    lcd.print("WiFi FAILED");
    delay(2000);
  }
  
  lcd.clear();
  lcd.print("READY");
  lcd.setCursor(0, 1);
  lcd.print("Waiting...");
  
  Serial.println("✓ System ready!");
  Serial.println("=================================\n");
}

// ============================================
// Main Loop
// ============================================
void loop() {
  // Check IR Sensor
  if (digitalRead(IR_SENSOR) == LOW) {
    Serial.println("\n🚨 IR SENSOR TRIGGERED - Vehicle detected!");
    handleVehicleDetection();
  }
  
  delay(100);
}

// ============================================
// Vehicle Detection Handler
// ============================================
void handleVehicleDetection() {
  digitalWrite(RED_LED, HIGH);  // Turn on red LED
  
  lcd.clear();
  lcd.print("VEHICLE");
  lcd.setCursor(0, 1);
  lcd.print("DETECTED!");
  
  Serial.println("📸 Requesting image capture from ESP32-CAM...");
  digitalWrite(YELLOW_LED, HIGH);  // Processing
  
  delay(1000);
  
  // Check distance
  while (getDistance() > 50) {
    Serial.print(".");
    lcd.clear();
    lcd.print("MOVE FORWARD");
    lcd.setCursor(0, 1);
    lcd.print("Distance: ");
    lcd.print(getDistance());
    delay(500);
  }
  
  // Trigger camera
  if (!triggerCamera()) {
    Serial.println("❌ Camera capture failed");
    lcd.clear();
    lcd.print("Camera Error");
    digitalWrite(RED_LED, LOW);
    digitalWrite(YELLOW_LED, LOW);
    return;
  }
  
  Serial.println("✓ Image captured");
  lcd.clear();
  lcd.print("PROCESSING");
  lcd.setCursor(0, 1);
  lcd.print("Detecting...");
  
  // Wait for result
  delay(3000);
  String result = getDetectionResult();
  
  digitalWrite(YELLOW_LED, LOW);
  
  lcd.clear();
  
  if (result == "ALLOW") {
    Serial.println("✓ ACCESS GRANTED - Opening gate");
    digitalWrite(GREEN_LED, HIGH);
    lcd.print("ACCESS OK");
    lcd.setCursor(0, 1);
    lcd.print(lastPlate);
    
    // Open gate
    gateServo.write(90);
    gateOpen = true;
    
    delay(5000);  // Keep open for 5 seconds
    
    // Wait for vehicle to pass
    while (getDistance() < 50) {
      delay(300);
    }
    
    // Close gate
    gateServo.write(0);
    gateOpen = false;
    digitalWrite(GREEN_LED, LOW);
    
  } else {
    Serial.println("✗ ACCESS DENIED");
    lcd.print("ACCESS DENIED");
    lcd.setCursor(0, 1);
    lcd.print(lastPlate);
    delay(3000);
  }
  
  digitalWrite(RED_LED, LOW);
  lcd.clear();
  lcd.print("READY");
  lcd.setCursor(0, 1);
  lcd.print("Waiting...");
}

// ============================================
// Trigger Camera
// Notifies Flask server to pull image from CAM
// ============================================
bool triggerCamera() {
  Serial.println("📡 Notifying Flask to trigger CAM...");

  HTTPClient camHttp;
  String url = "http://" + serverIP + ":5000/ir_trigger";
  Serial.println("URL: " + url);

  camHttp.begin(url);
  camHttp.setConnectTimeout(10000);
  camHttp.setTimeout(15000);

  int httpCode = camHttp.POST("");
  Serial.print("Flask HTTP Code: ");
  Serial.println(httpCode);

  camHttp.end();

  if (httpCode == 200) {
    Serial.println("✓ Flask notified - pulling image from CAM");
    return true;
  } else {
    Serial.print("❌ Flask HTTP error: ");
    Serial.println(httpCode);
    return false;
  }
}

// ============================================
// Get Detection Result from Server
// ============================================
String getDetectionResult() {
  Serial.println("📡 Connecting to Flask: " + serverIP);
  
  HTTPClient flaskHttp;
  String url = "http://" + serverIP + ":5000/result";
  Serial.println("URL: " + url);
  
  flaskHttp.begin(url);
  flaskHttp.setConnectTimeout(10000);
  flaskHttp.setTimeout(15000);
  
  int httpCode = flaskHttp.GET();
  Serial.print("Flask HTTP Code: ");
  Serial.println(httpCode);
  
  if (httpCode == 200) {
    String payload = flaskHttp.getString();
    flaskHttp.end();
    Serial.println("Response: " + payload);
    
    if (payload.indexOf("ALLOW") != -1) {
      return "ALLOW";
    } else {
      return "DENY";
    }
  } else {
    Serial.print("❌ Flask HTTP error: ");
    Serial.println(httpCode);
    flaskHttp.end();
    return "DENY";
  }
}

// ============================================
// Get Distance from Ultrasonic Sensor
// ============================================
int getDistance() {
  digitalWrite(ULTRASONIC_TRIG, LOW);
  delayMicroseconds(2);
  digitalWrite(ULTRASONIC_TRIG, HIGH);
  delayMicroseconds(10);
  digitalWrite(ULTRASONIC_TRIG, LOW);
  
  duration = pulseIn(ULTRASONIC_ECHO, HIGH);
  distance = duration * 0.034 / 2;
  
  return distance;
}


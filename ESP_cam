#include "esp_camera.h"
#include <WiFi.h>
#include <WebServer.h>

// ============================================
// CAMERA PIN CONFIGURATION (DO NOT CHANGE)
// ============================================
#define PWDN_GPIO_NUM     32
#define RESET_GPIO_NUM    -1
#define XCLK_GPIO_NUM      0
#define SIOD_GPIO_NUM     26
#define SIOC_GPIO_NUM     27

#define Y9_GPIO_NUM       35
#define Y8_GPIO_NUM       34
#define Y7_GPIO_NUM       39
#define Y6_GPIO_NUM       36
#define Y5_GPIO_NUM       21
#define Y4_GPIO_NUM       19
#define Y3_GPIO_NUM       18
#define Y2_GPIO_NUM        5
#define VSYNC_GPIO_NUM    25
#define HREF_GPIO_NUM     23
#define PCLK_GPIO_NUM     22

// ============================================
// WiFi Configuration - CHANGE THESE!
// ============================================
const char* ssid = "syedhaja";            // WiFi name
const char* password = "thasneem2011";    // WiFi password

// ============================================
// Server Configuration
// ============================================
WebServer server(80);

// IP Address of your Flask/Frontend server
String serverIP = "localhost";  // Frontend running at http://localhost:5000
// GitHub: https://github.com/godwin-stanes/AI_ANPR_PROJECT.git

// ============================================
// Setup
// ============================================
void setup() {
  Serial.begin(115200);
  delay(2000);
  
  Serial.println("\n\n=================================");
  Serial.println("🚗 SMART GATE - ESP32-CAM");
  Serial.println("=================================");
  
  // Initialize camera
  Serial.println("📷 Initializing camera...");
  if (!initCamera()) {
    Serial.println("❌ Camera init failed!");
    while(1);
  }
  Serial.println("✓ Camera ready!");
  
  // Connect to WiFi
  Serial.println("📡 Connecting to WiFi...");
  WiFi.begin(ssid, password);
  
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    delay(500);
    Serial.print(".");
    attempts++;
  }
  
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n✓ WiFi Connected!");
    Serial.print("📍 IP: ");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("\n❌ WiFi connection failed!");
  }
  
  // Setup endpoints
  server.on("/capture", HTTP_POST, handleCapture);
  server.on("/health", HTTP_GET, handleHealth);
  server.on("/stream", HTTP_GET, handleStream);
  server.on("/snapshot", HTTP_GET, handleSnapshot);
  server.on("/", HTTP_GET, handleRoot);
  server.onNotFound([]() {
    addCORSHeaders();
    server.send(204, "text/plain", "");
  });
  server.begin();
  
  Serial.println("✓ Web server started!");
  Serial.println("📷 Live stream: http://" + WiFi.localIP().toString() + "/stream");
  Serial.println("📸 Snapshot:    http://" + WiFi.localIP().toString() + "/snapshot");
  Serial.println("=================================\n");
}

// ============================================
// Main Loop
// ============================================
void loop() {
  server.handleClient();
}

// ============================================
// Initialize Camera - CHANGED for ANPR
// ============================================
bool initCamera() {
  camera_config_t config;
  
  config.ledc_channel = LEDC_CHANNEL_0;
  config.ledc_timer = LEDC_TIMER_0;
  config.pin_d0 = Y2_GPIO_NUM;
  config.pin_d1 = Y3_GPIO_NUM;
  config.pin_d2 = Y4_GPIO_NUM;
  config.pin_d3 = Y5_GPIO_NUM;
  config.pin_d4 = Y6_GPIO_NUM;
  config.pin_d5 = Y7_GPIO_NUM;
  config.pin_d6 = Y8_GPIO_NUM;
  config.pin_d7 = Y9_GPIO_NUM;
  config.pin_xclk = XCLK_GPIO_NUM;
  config.pin_pclk = PCLK_GPIO_NUM;
  config.pin_vsync = VSYNC_GPIO_NUM;
  config.pin_href = HREF_GPIO_NUM;
  config.pin_sscb_sda = SIOD_GPIO_NUM;
  config.pin_sscb_scl = SIOC_GPIO_NUM;
  config.pin_pwdn = PWDN_GPIO_NUM;
  config.pin_reset = RESET_GPIO_NUM;
  
  config.xclk_freq_hz = 20000000;
  config.pixel_format = PIXFORMAT_JPEG;
  config.frame_size = FRAMESIZE_VGA;
  config.jpeg_quality = 8;                 // ✅ CHANGED: sharper image for plate reading (was 10)
  config.fb_count = 2;                     // ✅ CHANGED: double buffer reduces capture lag (was 1)
  
  if (esp_camera_init(&config) != ESP_OK) {
    return false;
  }
  
  sensor_t * s = esp_camera_sensor_get();
  if (s != NULL) {
    s->set_brightness(s, 1);               // ✅ CHANGED: slight brightness boost (was 0)
    s->set_contrast(s, 1);                 // ✅ CHANGED: higher contrast helps OCR (was 0)
    s->set_saturation(s, 0);
    s->set_special_effect(s, 0);
    s->set_whitebal(s, 1);
    s->set_awb_gain(s, 1);
    s->set_wb_mode(s, 0);
    s->set_exposure_ctrl(s, 1);
    s->set_aec2(s, 1);                     // ✅ CHANGED: enable AEC2 for better auto exposure (was 0)
    s->set_aec_value(s, 300);
    s->set_agc_gain(s, 0);
    s->set_gainceiling(s, (gainceiling_t)0);
    s->set_bpc(s, 1);
    s->set_wpc(s, 1);
    s->set_raw_gma(s, 1);
    s->set_lenc(s, 1);
    s->set_hmirror(s, 0);
    s->set_vflip(s, 0);
    s->set_dcw(s, 1);
    s->set_colorbar(s, 0);
  }
  
  return true;
}

// ============================================
// Add CORS headers helper
// ============================================
void addCORSHeaders() {
  server.sendHeader("Access-Control-Allow-Origin", "*");
  server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
  server.sendHeader("Access-Control-Allow-Headers", "Content-Type");
}

// ============================================
// Capture Image Endpoint
// ============================================
void handleCapture() {
  addCORSHeaders();
  Serial.println("📸 Capture request received...");
  
  camera_fb_t * fb = esp_camera_fb_get();
  if (!fb) {
    Serial.println("❌ Camera capture failed");
    server.send(500, "text/plain", "Camera capture failed");
    return;
  }
  
  Serial.print("✓ Image size: ");
  Serial.print(fb->len);
  Serial.println(" bytes");
  
  // Send image data
  server.sendHeader("Content-Type", "image/jpeg");
  server.sendHeader("Content-Length", String(fb->len));
  server.send_P(200, "image/jpeg", (const char *)fb->buf, fb->len);
  
  esp_camera_fb_return(fb);
  Serial.println("✓ Image sent to server");
}

